<!-- Entry point for using OpenNI devices -->
<launch>

  <arg name="camera" default="sick_visionary_s" />
  <arg name="remote_device_ip" default="192.168.1.10" />
  <arg name="frame_id" default="camera" />

  <node pkg="sick_visionary" type="sick_visionary_s_node" name="$(arg camera)" output="screen" >
    <param name="remote_device_ip" value="$(arg remote_device_ip)" />
    <param name="frame_id" value="$(arg frame_id)" />
  </node>

</launch>
